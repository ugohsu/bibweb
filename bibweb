# ─── DB helpers ───────────────────────────────────────────────────────────────

def resolve_db(db_arg):
    if db_arg:
        return str(Path(db_arg).resolve())
    env = os.environ.get("BIBDB_PATH")
    if env:
        return env
    return str(Path.home() / "refs.db")


def get_conn(db_path):
    conn = sqlite3.connect(db_path)
    conn.row_factory = sqlite3.Row
    return conn


# jecon の is.kanji.str$ に相当: ひらがな・カタカナ・漢字・半角カナを検出
_CJK_RE = re.compile(r'[぀-ヿ一-鿿･-ﾟ]')


def _sort_name(entry):
    """jecon の sort.format.names に相当。
    yomi があればそれを使い、なければ author 第一著者の姓を正規化して返す。
    yomi はひらがなのため Unicode 順で ASCII より後に来る → 英語文献が自動的に前になる。"""
    yomi = (entry.get('yomi') or '').strip()
    if yomi:
        return yomi
    author = (entry.get('author') or '').strip()
    if not author:
        return ''
    first = re.split(r'\s+and\s+', author, flags=re.IGNORECASE)[0].strip()
    # "Last, First" 形式 → カンマ前が姓
    if ',' in first:
        last = first.split(',', 1)[0].strip()
    else:
        # "First Last" 形式 → 末尾の単語を姓とみなす
        parts = first.split()
        last = parts[-1] if parts else first
    # CJK 文字を含む場合はそのまま返す（yomi なし日本語文献の例外; CJK は Unicode 順で ASCII より後に来る）
    if _CJK_RE.search(last):
        return last
    # jecon の sortify 相当: 記号除去・小文字化（LaTeX コマンドも除去される）
    return re.sub(r'[^a-z0-9]', '', last.lower())


def _entry_sort_key(entry):
    """jecon の sort.key$ 相当: sort_name → year → title"""
    name  = _sort_name(entry)
    year  = entry.get('year') or '9999'
    title = re.sub(r'[^a-z0-9]', '', (entry.get('title') or '').lower())
    return (name, year, title)


def list_entries(db_path):
    with get_conn(db_path) as conn:
        rows = conn.execute("""
            SELECT e.id, e.cite_key, e.entry_type, e.added_at,
                   MAX(CASE WHEN f.field_key = 'title'    THEN f.field_value END) AS title,
                   MAX(CASE WHEN f.field_key = 'author'   THEN f.field_value END) AS author,
                   MAX(CASE WHEN f.field_key = 'year'     THEN f.field_value END) AS year,
                   MAX(CASE WHEN f.field_key = 'yomi'     THEN f.field_value END) AS yomi,
                   MAX(CASE WHEN f.field_key = 'language' THEN f.field_value END) AS language
            FROM entries e
            LEFT JOIN fields f ON f.entry_id = e.id
            GROUP BY e.id
        """).fetchall()
        entries = [dict(r) for r in rows]
        tag_rows = conn.execute(
            "SELECT entry_id, extra_value FROM extras WHERE extra_key = 'tags'"
        ).fetchall()
        tags_by_id = {}
        for tr in tag_rows:
            tags_by_id.setdefault(tr["entry_id"], []).append(tr["extra_value"])
        for e in entries:
            e["tags"] = sorted(tags_by_id.get(e["id"], []))
        entries.sort(key=_entry_sort_key)
        return entries


def get_entry(db_path, cite_key):
    with get_conn(db_path) as conn:
        row = conn.execute(
            "SELECT * FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not row:
            return None
        entry = dict(row)
        fields = conn.execute(
            "SELECT id, field_key, field_value FROM fields WHERE entry_id = ? ORDER BY field_key",
            (entry["id"],)
        ).fetchall()
        entry["fields"] = [dict(f) for f in fields]
        extras = conn.execute(
            "SELECT id, extra_key, extra_value FROM extras WHERE entry_id = ? ORDER BY extra_key",
            (entry["id"],)
        ).fetchall()
        entry["extras"] = [dict(x) for x in extras]
        return entry


def export_bib(db_path, cite_keys):
    with get_conn(db_path) as conn:
        blocks = []
        for key in cite_keys:
            row = conn.execute(
                "SELECT * FROM entries WHERE cite_key = ?", (key,)
            ).fetchone()
            if not row:
                continue
            fields = conn.execute(
                "SELECT field_key, field_value FROM fields WHERE entry_id = ?",
                (row["id"],)
            ).fetchall()
            lines = [f"@{row['entry_type']}{{{row['cite_key']},"]
            for f in fields:
                lines.append(f"  {f['field_key']} = {{{f['field_value']}}},")
            lines.append("}")
            blocks.append("\n".join(lines))
        return "\n\n".join(blocks)


_BIBDB_SCHEMA = """
CREATE TABLE entries (
    id         INTEGER  PRIMARY KEY AUTOINCREMENT,
    cite_key   TEXT     UNIQUE NOT NULL,
    entry_type TEXT     NOT NULL,
    added_at   DATETIME DEFAULT CURRENT_TIMESTAMP
);
CREATE TABLE fields (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    entry_id    INTEGER NOT NULL REFERENCES entries(id) ON DELETE CASCADE,
    field_key   TEXT    NOT NULL,
    field_value TEXT,
    UNIQUE(entry_id, field_key)
);
CREATE TABLE extras (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    entry_id    INTEGER NOT NULL REFERENCES entries(id) ON DELETE CASCADE,
    extra_key   TEXT    NOT NULL,
    extra_value TEXT
);
"""

def export_db(db_path, cite_keys):
    fd, tmp = tempfile.mkstemp(suffix=".db")
    os.close(fd)
    try:
        with sqlite3.connect(tmp) as dst:
            dst.executescript(_BIBDB_SCHEMA)
            with get_conn(db_path) as src:
                for key in cite_keys:
                    row = src.execute(
                        "SELECT * FROM entries WHERE cite_key = ?", (key,)
                    ).fetchone()
                    if not row:
                        continue
                    dst.execute(
                        "INSERT INTO entries (id, cite_key, entry_type, added_at) VALUES (?, ?, ?, ?)",
                        (row["id"], row["cite_key"], row["entry_type"], row["added_at"])
                    )
                    for f in src.execute(
                        "SELECT field_key, field_value FROM fields WHERE entry_id = ?",
                        (row["id"],)
                    ).fetchall():
                        dst.execute(
                            "INSERT INTO fields (entry_id, field_key, field_value) VALUES (?, ?, ?)",
                            (row["id"], f["field_key"], f["field_value"])
                        )
                    for x in src.execute(
                        "SELECT extra_key, extra_value FROM extras WHERE entry_id = ?",
                        (row["id"],)
                    ).fetchall():
                        dst.execute(
                            "INSERT INTO extras (entry_id, extra_key, extra_value) VALUES (?, ?, ?)",
                            (row["id"], x["extra_key"], x["extra_value"])
                        )
        with open(tmp, "rb") as f:
            return f.read()
    finally:
        os.unlink(tmp)


def update_field(db_path, cite_key, field_key, field_value):
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False
        conn.execute(
            "UPDATE fields SET field_value = ? WHERE entry_id = ? AND field_key = ?",
            (field_value, entry["id"], field_key)
        )
        return True


def delete_field(db_path, cite_key, field_key):
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False
        conn.execute(
            "DELETE FROM fields WHERE entry_id = ? AND field_key = ?",
            (entry["id"], field_key)
        )
        return True


def add_field(db_path, cite_key, field_key, field_value):
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False, "Entry not found"
        try:
            conn.execute(
                "INSERT INTO fields (entry_id, field_key, field_value) VALUES (?, ?, ?)",
                (entry["id"], field_key, field_value)
            )
            return True, None
        except sqlite3.IntegrityError:
            return False, f"Field '{field_key}' already exists"


def update_extra(db_path, extra_id, extra_value):
    with get_conn(db_path) as conn:
        conn.execute(
            "UPDATE extras SET extra_value = ? WHERE id = ?",
            (extra_value, extra_id)
        )
        return True


def delete_extra(db_path, extra_id):
    with get_conn(db_path) as conn:
        conn.execute("DELETE FROM extras WHERE id = ?", (extra_id,))
        return True


def add_extra(db_path, cite_key, extra_key, extra_value):
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False
        conn.execute(
            "INSERT INTO extras (entry_id, extra_key, extra_value) VALUES (?, ?, ?)",
            (entry["id"], extra_key, extra_value)
        )
        return True


def list_tags(db_path):
    with get_conn(db_path) as conn:
        rows = conn.execute("""
            SELECT extra_value AS name, COUNT(*) AS count
            FROM extras WHERE extra_key = 'tags'
            GROUP BY extra_value ORDER BY extra_value
        """).fetchall()
        return [dict(r) for r in rows]


def add_tag(db_path, cite_key, tag_name):
    tag_name = tag_name.strip()
    if not tag_name:
        return False, "タグ名が空です"
    if len(tag_name) > 50:
        return False, "タグは50文字以内にしてください"
    if ',' in tag_name:
        return False, "タグにカンマは使えません"
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False, "Entry not found"
        dup = conn.execute(
            "SELECT id FROM extras WHERE entry_id = ? AND extra_key = 'tags' AND extra_value = ?",
            (entry["id"], tag_name)
        ).fetchone()
        if dup:
            return False, "すでに同じタグが付いています"
        conn.execute(
            "INSERT INTO extras (entry_id, extra_key, extra_value) VALUES (?, 'tags', ?)",
            (entry["id"], tag_name)
        )
        return True, None


def delete_tag(db_path, cite_key, tag_name):
    with get_conn(db_path) as conn:
        entry = conn.execute(
            "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
        ).fetchone()
        if not entry:
            return False
        conn.execute(
            "DELETE FROM extras WHERE entry_id = ? AND extra_key = 'tags' AND extra_value = ?",
            (entry["id"], tag_name)
        )
        return True


def bulk_add_tag(db_path, cite_keys, tag_name):
    tag_name = tag_name.strip()
    if not tag_name:
        return False, "タグ名が空です"
    if len(tag_name) > 50:
        return False, "タグは50文字以内にしてください"
    if ',' in tag_name:
        return False, "タグにカンマは使えません"
    with get_conn(db_path) as conn:
        for cite_key in cite_keys:
            entry = conn.execute(
                "SELECT id FROM entries WHERE cite_key = ?", (cite_key,)
            ).fetchone()
            if not entry:
                continue
            dup = conn.execute(
                "SELECT id FROM extras WHERE entry_id = ? AND extra_key = 'tags' AND extra_value = ?",
                (entry["id"], tag_name)
            ).fetchone()
            if dup:
                continue
            conn.execute(
                "INSERT INTO extras (entry_id, extra_key, extra_value) VALUES (?, 'tags', ?)",
                (entry["id"], tag_name)
            )
    return True, None

# ─── Cache management ─────────────────────────────────────────────────────────

def ensure_cache(force=False):
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    all_ok = True

    for fname in REPO_FILES:
        dest = CACHE_DIR / fname
        if force or not dest.exists():
            url = f"{GITHUB_RAW_BASE}/{fname}"
            print(f"  {fname} ... ", end="", flush=True)
            try:
                urllib.request.urlretrieve(url, dest)
                print("OK")
            except Exception as e:
                print(f"FAILED ({e})")
                all_ok = False

    for fname, url in LIB_URLS.items():
        dest = CACHE_DIR / fname
        if force or not dest.exists():
            print(f"  {fname} ... ", end="", flush=True)
            try:
                urllib.request.urlretrieve(url, dest)
                print("OK")
            except Exception as e:
                print(f"FAILED ({e})")
                all_ok = False

    if not all_ok:
        print("One or more files failed to download.", file=sys.stderr)
        sys.exit(1)
    print("Cache ready.")

# ─── HTTP Handler ─────────────────────────────────────────────────────────────

class BibWebHandler(BaseHTTPRequestHandler):
    db_path = None

    def log_message(self, format, *args):
        pass  # suppress access log

    def send_json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False, default=str).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_error_json(self, status, message):
        self.send_json({"error": message}, status)

    def read_json_body(self):
        length = int(self.headers.get("Content-Length", 0))
        if length == 0:
            return {}
        return json.loads(self.rfile.read(length))

    def serve_cached(self, fname):
        path = CACHE_DIR / fname
        if not path.exists():
            self.send_response(404)
            self.end_headers()
            return
        data = path.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", MIME.get(path.suffix, "application/octet-stream"))
        self.send_header("Content-Length", str(len(data)))
        self.send_header("Cache-Control", "no-cache")
        self.end_headers()
        self.wfile.write(data)

    def do_GET(self):
        path = urlparse(self.path).path.rstrip("/") or "/"

        if path in ("/", "/index.html"):
            self.serve_cached("index.html")

        elif path.startswith("/static/"):
            fname = unquote(path[len("/static/"):])
            if "/" in fname or fname.startswith("."):
                self.send_error_json(400, "Invalid path")
                return
            self.serve_cached(fname)

        elif path == "/api/db":
            self.send_json({"path": self.db_path})

        elif path == "/api/tags":
            self.send_json(list_tags(self.db_path))

        elif path == "/api/entries":
            self.send_json(list_entries(self.db_path))

        elif path.startswith("/api/entries/"):
            parts = path.split("/")
            # /api/entries/{key}
            if len(parts) == 4:
                cite_key = unquote(parts[3])
                entry = get_entry(self.db_path, cite_key)
                if entry:
                    self.send_json(entry)
                else:
                    self.send_error_json(404, "Entry not found")
            else:
                self.send_error_json(404, "Not found")

        else:
            self.send_error_json(404, "Not found")

    def do_POST(self):
        path = urlparse(self.path).path
        parts = path.split("/")

        # POST /api/tags/bulk
        if path == "/api/tags/bulk":
            body = self.read_json_body()
            ok, err = bulk_add_tag(self.db_path, body.get("keys", []), body.get("name", ""))
            if ok:
                self.send_json({"ok": True})
            else:
                self.send_error_json(409, err)

        # POST /api/export
        elif path == "/api/export":
            body = self.read_json_body()
            bib = export_bib(self.db_path, body.get("keys", []))
            data = bib.encode()
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Disposition", 'attachment; filename="export.bib"')
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        # POST /api/export/db
        elif path == "/api/export/db":
            body = self.read_json_body()
            data = export_db(self.db_path, body.get("keys", []))
            self.send_response(200)
            self.send_header("Content-Type", "application/x-sqlite3")
            self.send_header("Content-Disposition", 'attachment; filename="export.db"')
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        # POST /api/entries/{key}/fields
        elif len(parts) == 5 and parts[4] == "fields":
            cite_key = unquote(parts[3])
            body = self.read_json_body()
            ok, err = add_field(self.db_path, cite_key, body.get("field_key", ""), body.get("field_value", ""))
            if ok:
                self.send_json({"ok": True})
            else:
                self.send_error_json(409, err)

        # POST /api/entries/{key}/extras
        elif len(parts) == 5 and parts[4] == "extras":
            cite_key = unquote(parts[3])
            body = self.read_json_body()
            ok = add_extra(self.db_path, cite_key, body.get("extra_key", ""), body.get("extra_value", ""))
            self.send_json({"ok": ok})

        # POST /api/entries/{key}/tags
        elif len(parts) == 5 and parts[4] == "tags":
            cite_key = unquote(parts[3])
            body = self.read_json_body()
            ok, err = add_tag(self.db_path, cite_key, body.get("name", ""))
            if ok:
                self.send_json({"ok": True})
            else:
                self.send_error_json(409, err)

        else:
            self.send_error_json(404, "Not found")

    def do_PUT(self):
        path = urlparse(self.path).path
        parts = path.split("/")

        # PUT /api/entries/{key}/fields/{field_key}
        if len(parts) == 6 and parts[2] == "entries" and parts[4] == "fields":
            cite_key = unquote(parts[3])
            field_key = unquote(parts[5])
            body = self.read_json_body()
            ok = update_field(self.db_path, cite_key, field_key, body.get("field_value", ""))
            self.send_json({"ok": ok})

        # PUT /api/extras/{id}
        elif len(parts) == 4 and parts[2] == "extras":
            try:
                extra_id = int(parts[3])
            except ValueError:
                self.send_error_json(400, "Invalid id")
                return
            body = self.read_json_body()
            ok = update_extra(self.db_path, extra_id, body.get("extra_value", ""))
            self.send_json({"ok": ok})

        else:
            self.send_error_json(404, "Not found")

    def do_DELETE(self):
        path = urlparse(self.path).path
        parts = path.split("/")

        # DELETE /api/entries/{key}/fields/{field_key}
        if len(parts) == 6 and parts[2] == "entries" and parts[4] == "fields":
            cite_key = unquote(parts[3])
            field_key = unquote(parts[5])
            ok = delete_field(self.db_path, cite_key, field_key)
            self.send_json({"ok": ok})

        # DELETE /api/extras/{id}
        elif len(parts) == 4 and parts[2] == "extras":
            try:
                extra_id = int(parts[3])
            except ValueError:
                self.send_error_json(400, "Invalid id")
                return
            ok = delete_extra(self.db_path, extra_id)
            self.send_json({"ok": ok})

        # DELETE /api/entries/{key}/tags/{name}
        elif len(parts) == 6 and parts[2] == "entries" and parts[4] == "tags":
            cite_key = unquote(parts[3])
            tag_name = unquote(parts[5])
            ok = delete_tag(self.db_path, cite_key, tag_name)
            self.send_json({"ok": ok})

        else:
            self.send_error_json(404, "Not found")

# ─── Main ─────────────────────────────────────────────────────────────────────

def main():
    parser = argparse.ArgumentParser(description="Web UI for bibdb")
    parser.add_argument("db", nargs="?", help="Path to the bibdb SQLite file")
    parser.add_argument("--port", "-p", type=int, default=DEFAULT_PORT, metavar="PORT")
    parser.add_argument("--update", action="store_true", help="Re-download all cached files and exit")
    args = parser.parse_args()

    if args.update:
        print("Updating cache...")
        ensure_cache(force=True)
        return

    db_path = resolve_db(args.db)

    if not Path(db_path).exists():
        print(f"Error: database not found: {db_path}", file=sys.stderr)
        print("Set $BIBDB_PATH or pass a path as argument.", file=sys.stderr)
        sys.exit(1)

    # Download UI files on first run
    if not all((CACHE_DIR / f).exists() for f in REPO_FILES):
        print("First run: downloading UI files...")
        ensure_cache()

    BibWebHandler.db_path = db_path

    url = f"http://localhost:{args.port}"
    print(f"bibweb  {url}")
    print(f"DB      {db_path}")
    print("Press Ctrl+C to stop.")

    server = HTTPServer(("localhost", args.port), BibWebHandler)
    threading.Timer(0.6, lambda: webbrowser.open(url)).start()

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nStopped.")


if __name__ == "__main__":
    main()
